{
	"$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
	"vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
	"files": { "ignoreUnknown": true, "ignore": [".next", "node_modules", "build", "dist", "generated"] },
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 2,
		"lineWidth": 100
	},
	"organizeImports": { "enabled": true },
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"correctness": { "noUnusedImports": "warn", "noUnusedVariables": "warn" },
			"style": {
				"noNonNullAssertion": "off",
				"useConst": "error",
				"useImportType": "warn"
			},
			"suspicious": { "noExplicitAny": "warn" }
		},
		"ignore": [
			"next-env.d.ts",
			"node_modules",
			"build",
			"dist",
			"out",
			"public",
			"styles",
			"types",
			"/*tiptap*/**/*"
		]
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"semicolons": "always",
			"trailingCommas": "es5"
		}
	}
}
