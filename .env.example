

# Local Postgres (development). Run: npm run db:create
LOCAL_DATABASE_URL="postgresql://localhost:5432/app_dev"

# Production / Neon — used by both Prisma and raw queries
# For local dev, set to same as LOCAL_DATABASE_URL (Prisma uses this)
# DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"
DATABASE_URL="postgresql://localhost:5432/app_dev"


# Clerk (https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
# Optional: match hosted sign-in/up routes (defaults work if you use /sign-in and /sign-up)
# NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
# NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# Realtime collaboration (Hocuspocus + signed collab tokens)
# Generate a long random string for COLLAB_JWT_SECRET (shared by Next.js and the collab server)
COLLAB_JWT_SECRET=""
# WebSocket URL for the Hocuspocus server (browser)
NEXT_PUBLIC_HOCUSPOCUS_URL="ws://127.0.0.1:1234"
