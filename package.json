		"@trpc/server": "^11.0.0",
		"@trpc/tanstack-react-query": "^11.0.0",
		"client-only": "^0.0.1",
		"clsx": "^2.1.1",
		"dotenv": "^17.3.1",
		"jose": "^6.2.2",
		"lodash.throttle": "^4.1.1",
		"lucide-react": "^0.577.0",
		"next": "16.1.7",
		"pg": "^8.20.0",
		"radix-ui": "^1.4.3",
		"react": "19.2.3",
		"react-dom": "19.2.3",
		"react-hotkeys-hook": "^5.2.4",
		"server-only": "^0.0.1",
		"shadcn": "^4.0.8",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.5.0",
		"tw-animate-css": "^1.4.0",
		"y-indexeddb": "^9.0.12",
		"yjs": "^13.6.30",
		"zod": "^3.24.0"
