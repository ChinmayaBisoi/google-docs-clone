{
	"name": "google-docs-clone",
	"description": "Google Docs Clone",
	"author": "Chinmaya Bisoi",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/ChinmayaBisoi/google-docs-clone.git"
	},
	"homepage": "https://github.com/ChinmayaBisoi/google-docs-clone",
	"keywords": [
		"google-docs-clone",
		"google-docs",
		"docs",
		"google",
		"clone"
	],
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"start": "next start",
		"lint": "biome lint .",
		"lint:fix": "biome lint --write .",
		"format": "biome format --write .",
		"check": "biome check .",
		"check:fix": "biome check --write .",
		"db:create": "bash scripts/create-db.sh",
		"postinstall": "prisma generate",
		"db:generate": "prisma generate",
		"db:migrate": "prisma migrate dev && prisma generate",
		"db:push": "prisma db push && prisma generate",
		"db:studio": "prisma studio",
		"collab": "tsx server/hocuspocus.ts",
		"dev:all": "concurrently \"npm run dev\" \"npm run collab\""
	},
	"dependencies": {
		"@clerk/nextjs": "^7.0.5",
		"@floating-ui/react": "^0.27.19",
